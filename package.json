{
  "name": "@cmts-dev/carmentis-desk-connect-js",
  "version": "1.1.0",
  "description": "Framework-agnostic JS SDK for connecting web applications to Carmentis Desk",
  "type": "module",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "license": "Apache-2.0",
  "private": false,
  "scripts": {
    "build": "vite build"
  },
  "dependencies": {
    "@cmts-dev/carmentis-relay-client": "^1.2.0",
    "@cmts-dev/carmentis-sdk-json-rpc": "^1.0.2"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "semantic-release": "^24.2.0",
    "typescript": "^5.5.3",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
